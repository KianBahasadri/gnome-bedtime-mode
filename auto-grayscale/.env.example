# auto-grayscale configuration overrides.
# Uncomment and edit any line to override the script's built-in defaults.

# Latitude and longitude (north-positive, east-positive).
# Default: Toronto, ON.
# LAT=43.6532
# LON=-79.3832

# Sun altitude in degrees for the sunrise/sunset calculation.
# -0.833: standard (sun's limb at horizon, with refraction)
# -6    : civil twilight (later switch-off at sunset, earlier at sunrise)
# SUN_ALTITUDE=-0.833

# Set ENABLED=false to keep bedtime mode off while the service keeps running.
# You can toggle this at any time -- the daemon re-reads .env every loop.
# ENABLED=true
